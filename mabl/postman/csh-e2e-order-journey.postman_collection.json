{
  "info": {
    "name": "CSH-CHP-CHECKOUT-API-CustomerPlacesOrderEndToEnd",
    "description": "End-to-end API journey for Cheap Shot Hockey: catalog browse → authenticate → add to cart → place order → verify. 9 chained requests. Imports into mabl as an API test.\n\nBase URL is driven by the `baseUrl` collection variable. Set it to http://localhost:3000/api for Local, https://cheap-shot-hockey.vercel.app/api for Production, etc.\n\nBrittleness policy: assertions are split into two tiers.\n- STRUCTURAL (existence/type): catches true outages. Should only fail on a real regression.\n- BUSINESS-LOGIC (exact values): catches price/tax/shipping math regressions. Intentionally strict — totalCents, taxCents, shippingCents use equality because their values are the whole point of the test.\n\nmabl Postman-import caveat: pm.collectionVariables.set() in step 7 does NOT currently port into a mabl variable setter on import. After importing, manually add a response variable extraction on step 7: name=`orderId`, JSONPath=`$.id`, scope=`@` (test-scope). See docs/MABL-API-TESTS.md for full instructions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1 - Catalog: list products",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/products",
          "host": ["{{baseUrl}}"],
          "path": ["products"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('catalog returns products', () => pm.expect(body.count).to.be.above(0));",
              "pm.test('items array shape', () => pm.expect(body.items).to.be.an('array').and.not.empty);"
            ]
          }
        }
      ]
    },
    {
      "name": "2 - Catalog: deep-link by slug",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/products/apex-velocity-pro-stick",
          "host": ["{{baseUrl}}"],
          "path": ["products", "apex-velocity-pro-stick"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('product has an id', () => pm.expect(body.id).to.be.a('string').and.not.empty);",
              "pm.test('salePriceCents is 19999 (business-logic: price change = real signal)', () => pm.expect(body.salePriceCents).to.eql(19999));"
            ]
          }
        }
      ]
    },
    {
      "name": "3 - Auth: login as demo customer",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"demo@cheapshot.test\",\n  \"password\": \"demo1234\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('user has an id', () => pm.expect(body.id).to.be.a('string').and.not.empty);",
              "pm.test('role is customer', () => pm.expect(body.role).to.eql('customer'));"
            ]
          }
        }
      ]
    },
    {
      "name": "4 - Auth: session cookie persists via /me",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "me"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('session resolves a user', () => pm.expect(body.id).to.be.a('string').and.not.empty);"
            ]
          }
        }
      ]
    },
    {
      "name": "5 - Cart: add 1 Apex Velocity stick",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": \"p-stk-001\",\n  \"quantity\": 1,\n  \"mode\": \"add\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/cart",
          "host": ["{{baseUrl}}"],
          "path": ["cart"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('cart has a line', () => pm.expect(body.lines).to.be.an('array').and.not.empty);",
              "pm.test('line productId matches requested', () => pm.expect(body.lines[0].productId).to.eql('p-stk-001'));",
              "pm.test('line quantity is 1', () => pm.expect(body.lines[0].quantity).to.eql(1));"
            ]
          }
        }
      ]
    },
    {
      "name": "6 - Cart: read persists across request",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/cart",
          "host": ["{{baseUrl}}"],
          "path": ["cart"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('subtotalCents is 19999 (business-logic: sale price)', () => pm.expect(body.subtotalCents).to.eql(19999));"
            ]
          }
        }
      ]
    },
    {
      "name": "7 - Checkout: place the order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"shippingAddress\": {\n    \"name\": \"Demo Customer\",\n    \"street\": \"1 Rink Road\",\n    \"city\": \"Minneapolis\",\n    \"state\": \"MN\",\n    \"postalCode\": \"55401\",\n    \"country\": \"US\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/orders",
          "host": ["{{baseUrl}}"],
          "path": ["orders"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.test('status is paid', () => pm.expect(body.status).to.eql('paid'));",
              "pm.test('order has a userId', () => pm.expect(body.userId).to.be.a('string').and.not.empty);",
              "pm.test('shippingCents is 0 (business-logic: free over $99)', () => pm.expect(body.shippingCents).to.eql(0));",
              "pm.test('taxCents is 1600 (business-logic: 8% of $199.99)', () => pm.expect(body.taxCents).to.eql(1600));",
              "pm.test('totalCents is 21599 (business-logic: subtotal + tax + shipping)', () => pm.expect(body.totalCents).to.eql(21599));",
              "// Extract order id for step 9 (Postman-only; mabl requires a separate native extraction — see collection description)",
              "pm.collectionVariables.set('orderId', body.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "8 - Cart cleared after order",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/cart",
          "host": ["{{baseUrl}}"],
          "path": ["cart"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('cart empty', () => pm.expect(body.subtotalCents).to.eql(0));"
            ]
          }
        }
      ]
    },
    {
      "name": "9 - Order retrievable by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/orders/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["orders", "{{orderId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('order is paid', () => pm.expect(body.status).to.eql('paid'));",
              "pm.test('totalCents is 21599 (business-logic: end-to-end math consistent)', () => pm.expect(body.totalCents).to.eql(21599));"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "description": "Override per env: http://localhost:3000/api (Local) | https://cheap-shot-hockey-git-main-vincemahan-1163s-projects.vercel.app/api (Preview) | https://cheap-shot-hockey.vercel.app/api (Production)"
    },
    {
      "key": "orderId",
      "value": "",
      "description": "Populated by step 7 response. In Postman: via pm.collectionVariables.set. In mabl: add a native response extraction on step 7 (JSONPath $.id) — the pm.* setter does not port on import."
    }
  ]
}
