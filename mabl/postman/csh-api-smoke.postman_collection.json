              "pm.test('session resolves a user', () => pm.expect(body.id).to.be.a('string').and.not.empty);"
            ]
          }
        }
      ]
    },
    {
      "name": "CSH-CHP-05 Cart: add Apex Velocity",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": \"p-stk-001\",\n  \"quantity\": 1,\n  \"mode\": \"add\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/cart",
          "host": ["{{baseUrl}}"],
          "path": ["cart"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('cart has a line', () => pm.expect(body.lines).to.be.an('array').and.not.empty);",
              "pm.test('line productId matches', () => pm.expect(body.lines[0].productId).to.eql('p-stk-001'));",
              "pm.test('line qty is 1', () => pm.expect(body.lines[0].quantity).to.eql(1));"
            ]
          }
        }
      ]
    },
    {
      "name": "CSH-CHP-06 Cart: persists",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/cart",
          "host": ["{{baseUrl}}"],
          "path": ["cart"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('subtotalCents 19999', () => pm.expect(body.subtotalCents).to.eql(19999));"
            ]
          }
        }
      ]
    },
    {
      "name": "CSH-CHP-07 Checkout: place order",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"shippingAddress\": {\n    \"name\": \"Demo Customer\",\n    \"street\": \"1 Rink Road\",\n    \"city\": \"Minneapolis\",\n    \"state\": \"MN\",\n    \"postalCode\": \"55401\",\n    \"country\": \"US\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/orders",
          "host": ["{{baseUrl}}"],
          "path": ["orders"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', () => pm.response.to.have.status(201));",
              "const body = pm.response.json();",
              "pm.test('status is paid', () => pm.expect(body.status).to.eql('paid'));",
              "pm.test('userId present', () => pm.expect(body.userId).to.be.a('string').and.not.empty);",
              "pm.test('shippingCents is 0', () => pm.expect(body.shippingCents).to.eql(0));",
              "pm.test('taxCents is 1600', () => pm.expect(body.taxCents).to.eql(1600));",
              "pm.test('totalCents is 21599', () => pm.expect(body.totalCents).to.eql(21599));",
              "pm.collectionVariables.set('orderId', body.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "CSH-CHP-08 Cart cleared",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/cart",
          "host": ["{{baseUrl}}"],
          "path": ["cart"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('cart empty', () => pm.expect(body.subtotalCents).to.eql(0));"
            ]
          }
        }
      ]
    },
    {
      "name": "CSH-CHP-09 Order retrievable",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/orders/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["orders", "{{orderId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('order is paid', () => pm.expect(body.status).to.eql('paid'));",
              "pm.test('totalCents is 21599', () => pm.expect(body.totalCents).to.eql(21599));"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "description": "Override via newman --env-var baseUrl=... for Preview/Prod runs"
    },
    {
      "key": "orderId",
      "value": "",
      "description": "Populated by step CSH-CHP-07 via pm.collectionVariables.set"
    }
  ]
}
