# =============================================================================
# Reference architecture — config.env.example
# =============================================================================
# This file catalogues every customer-replaceable value in the agentic SDLC
# pattern. Customers forking this repo replace each placeholder with their
# own value, then add them as GitHub repo secrets (or a self-hosted CI
# secrets store).
#
# DO NOT commit a real `config.env` file with real values — secrets belong
# in your CI's secret store, not in git.
#
# See `docs/FORK-GUIDE.md` for the step-by-step "how to fork and deploy"
# walkthrough.
# =============================================================================


# -----------------------------------------------------------------------------
# mabl — required for the browser-layer gates and post-deploy verification
# -----------------------------------------------------------------------------

# Workspace UUID. From mabl Settings → Workspace → "ID" field.
# In the cheap-shot-hockey demo: pXXgThbNi4HfQOpiZptHfw-w
MABL_WORKSPACE_ID=

# Application UUID. Created when you add an Application in mabl.
# In the cheap-shot-hockey demo: OZqmshBkUfVSesWy49g1eQ-a
MABL_APPLICATION_ID=

# Environment UUIDs — one per environment that the gates target.
# In the cheap-shot-hockey demo, two envs: Preview (PR gates) and Prod
# (post-deploy verification + scheduled monitoring).
MABL_ENV_PREVIEW_ID=
MABL_ENV_PROD_ID=

# (Optional) A "local" env if you want to run mabl locally during dev.
MABL_ENV_LOCAL_ID=

# API token. From mabl Settings → APIs → "Create API token". The user
# associated with the token needs Plan Run + Test Author scopes.
MABL_API_TOKEN=


# -----------------------------------------------------------------------------
# Slack — required for autonomous CI notifications
# -----------------------------------------------------------------------------

# Channel ID for gate-by-gate posts. NOT the channel name — the ID.
# Find it via Slack → channel → "View channel details" → bottom of modal.
# In the cheap-shot-hockey demo: C0A321B477Y (#vince-agentic-workflow-demos)
SLACK_CHANNEL_ID=

# Workflow Builder webhook URL — the no-admin-required posting path.
# Create a Slack Workflow that takes a JSON `text` field and posts it
# to the channel above. Webhook URL goes here.
# Limitation: the WFB webhook can't thread and has restricted mrkdwn.
SLACK_WEBHOOK_URL=

# (Optional, recommended) Bot or user OAuth token (xoxb- or xoxp-).
# If set, ci-notify.sh prefers this and uses chat.postMessage — gives
# rich mrkdwn, threaded replies, and proper labeled links. Requires
# either workspace-admin install (xoxb-) or personal Slack app with
# user-token install (xoxp-).
SLACK_BOT_TOKEN=


# -----------------------------------------------------------------------------
# Jira — required for ticket lifecycle automation + audit trail comments
# -----------------------------------------------------------------------------

# Jira base URL. Always your Atlassian site URL, no trailing slash.
# In the cheap-shot-hockey demo: https://mabl.atlassian.net
JIRA_BASE_URL=

# Jira project key — the prefix on every ticket (e.g. TAMD-99 → "TAMD").
# In the cheap-shot-hockey demo: TAMD
# Customers should NOT reuse this; pick your own project key.
JIRA_PROJECT_KEY=

# Jira API auth — basic auth pair. The user needs Edit Issue + Add
# Comment + Transition Issue permissions on the project.
JIRA_USER_EMAIL=
JIRA_API_TOKEN=


# -----------------------------------------------------------------------------
# GitHub + deployment URLs
# -----------------------------------------------------------------------------

# Your production URL. Used by post-deploy verification and the recovery
# agent's prod state checks (/api/build-info, /api/health).
# In the cheap-shot-hockey demo: https://cheap-shot-hockey.vercel.app
PROD_URL=

# (Optional) Jenkins job URL if you run Jenkins in parallel with GHA.
# When set, ci-notify.sh adds a "Jenkins job" link to every gate post
# for traceability.
JENKINS_JOB_URL=


# -----------------------------------------------------------------------------
# Anthropic — required for the failure-recovery diagnosis agent
# -----------------------------------------------------------------------------

# Anthropic API key. Get one at console.anthropic.com → Settings → API
# Keys. Used by scripts/recovery-agent/index.js to invoke the Agent
# SDK on post-deploy failure.
#
# Without this, the recovery agent emits a fail-safe page-human
# recommendation and exits 0 — the architecture works, but the live
# diagnosis loop doesn't fire. Cost is trivial (~$0.01-$0.05 per
# diagnosis).
ANTHROPIC_API_KEY=


# -----------------------------------------------------------------------------
# Where these values get used (for fork-time replacement)
# -----------------------------------------------------------------------------
# Most of the above are wired in via repo secrets and read in
# .github/workflows/mabl-sdlc.yml. A few are hardcoded in the YAML
# itself (search for the demo values listed above) and need a one-time
# find-replace when forking. See `docs/FORK-GUIDE.md` step 6 for the
# exact list.
